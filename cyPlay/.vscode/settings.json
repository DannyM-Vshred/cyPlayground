{
    "cucumberautocomplete.steps": [
        "src/Ecommerce/StoreFront/cypress/support/step_definitions/**/*.ts",
        "src/Ecommerce/_libs/step_definitions/**/*.ts"
    ],
    "cucumberautocomplete.strictGherkinCompletion": false,
    "cucumberautocomplete.strictGherkinValidation": false,
    "cucumberautocomplete.gherkinDefinitionPart": "(Given|When|Then|And|But)\\(",
    "cucumberautocomplete.stepRegExSymbol": "'",
    "files.associations": {
        "*.feature": "feature"
    },
    "[feature]": {
        "editor.quickSuggestions": {
            "strings": true,
            "other": true
        }
    }
}
